# OpenAI
OPENAI_API_KEY=sk-...

# Firebase (base64-encoded service account JSON for production)
FIREBASE_ADMIN_BASE64=
# Or for local dev, place firebase_admin_sdk.json in backend/

# Weaviate
WEAVIATE_URL=http://weaviate:8080

# Stripe
STRIPE_SECRET_KEY=sk_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRICE_ID=price_...

# AWS
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=
AWS_S3_BUCKET_NAME=

# App
FRONTEND_URL=https://yourdomain.com

FIREBASE_STORAGE_BUCKET=

# Logging
LOG_LEVEL=INFO
# Set to "dev" for colored console output locally
LOG_FORMAT=
